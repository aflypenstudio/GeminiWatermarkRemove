{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Banana Watermark Remover",
  "version": "1.0.0",
  "identifier": "com.aflypenstudio.banana-watermark-remover",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "巴娜娜去水印&微調器 - Banana Watermark Remover",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": [
          "zh-TW",
          "en-US",
          "ja-JP",
          "ko-KR",
          "zh-CN"
        ]
      }
    }
  }
}